---
import InstaIcon from "./InstaIcon.astro";
import FbIcon from "./FbIcon.astro";
const RECAPTCHA_SITE_KEY = import.meta.env.PUBLIC_RECAPTCHA_SITE_KEY;
---

<section class="padding-big section-bg-color" id="contact">
  <div class="container pgb-signup__inner">
    <div class="pgb-signup__copy">
      <h2>Een vraag? Laat gerust van je horen.</h2>
      <p class="text-signup">
        Stuur een bericht over PGB Planner. Wil je alleen op de hoogte blijven van nieuwe ontwikkelingen en artikelen? Dat kan ook.
      </p>
      <div>
        <a
          href="mailto:info@pgbplanner.nl"
          target="_blank"
          rel="noopener noreferrer"
          class="pgb-mail-link"
        >
          <svg
            width="20"
            height="20"
            viewBox="0 0 24 24"
            fill="none"
            xmlns="http://www.w3.org/2000/svg"
            aria-hidden="true"
          >
            <path
              d="M2 6L8.91302 9.91697C11.4616 11.361 12.5384 11.361 15.087 9.91697L22 6"
              stroke="currentColor"
              stroke-width="1.5"
              stroke-linejoin="round"></path>
            <path
              d="M2.01577 13.4756C2.08114 16.5412 2.11383 18.0739 3.24496 19.2094C4.37608 20.3448 5.95033 20.3843 9.09883 20.4634C11.0393 20.5122 12.9607 20.5122 14.9012 20.4634C18.0497 20.3843 19.6239 20.3448 20.7551 19.2094C21.8862 18.0739 21.9189 16.5412 21.9842 13.4756C22.0053 12.4899 22.0053 11.5101 21.9842 10.5244C21.9189 7.45886 21.8862 5.92609 20.7551 4.79066C19.6239 3.65523 18.0497 3.61568 14.9012 3.53657C12.9607 3.48781 11.0393 3.48781 9.09882 3.53656C5.95033 3.61566 4.37608 3.65521 3.24495 4.79065C2.11382 5.92608 2.08114 7.45885 2.01576 10.5244C1.99474 11.5101 1.99475 12.4899 2.01577 13.4756Z"
              stroke="currentColor"
              stroke-width="1.5"
              stroke-linejoin="round"></path>
          </svg>
          <span>info@pgbplanner.nl</span>
        </a>
      </div>
      <p class="text-ps">
        Je ontvangt alleen updates als je het vakje aanvinkt. Uitschrijven kan altijd.
      </p>
      <div class="socials-wrapper">
        <a
          href="https://www.instagram.com/pgbplanner/"
          target="_blank"
          rel="noopener noreferrer"
          class="pgb-mail-link"
        >
          <InstaIcon />
          <span>@pgbplanner</span>
        </a>
        <span>|</span>
        <a
          href="https://www.facebook.com/pgbplanner"
          target="_blank"
          rel="noopener noreferrer"
          class="pgb-mail-link"
        >
          <FbIcon />
          <span>PGB Planner</span>
        </a>
      </div>
    </div>

    <form id="pgb-form" class="pgb-signup__form">
      <label class="pgb-field">
        <span class="pgb-label">Naam</span>
        <input
          type="text"
          name="name"
          id="pgb-name"
          placeholder="Naam"
          autocomplete="name"
          maxlength="200"
          required
        />
      </label>

      <label class="pgb-field">
        <span class="pgb-label">Email</span>
        <input
          type="email"
          name="email"
          id="pgb-email"
          placeholder="Email"
          autocomplete="email"
          maxlength="254"
          required
        />
      </label>

      <label class="pgb-field">
        <span class="pgb-label">Welke PGB heb je? (optioneel)</span>
        <select name="pgbType" id="pgb-type">
          <option value="" selected>Welke PGB heb je? (optioneel)</option>
          <option value="Wlz">Wlz</option>
          <option value="Wmo">Wmo</option>
          <option value="Jeugdwet">Jeugdwet</option>
          <option value="Zvw">Zvw</option>
          <option value="Meerdere">Meerdere</option>
          <option value="Weet ik niet">Weet ik niet</option>
        </select>
      </label>

      <label class="pgb-field">
        <span class="pgb-label">Bericht (optioneel)</span>
        <textarea
          name="message"
          id="pgb-message"
          rows="5"
          placeholder="Stel gerust je vraag"
          maxlength="2000"
        ></textarea>
      </label>

      <label class="pgb-checkbox">
        <input type="checkbox" name="subscribeToUpdates" id="pgb-updates" />
        <span class="pgb-checkbox__label"
          >Houd me op de hoogte van nieuwe ontwikkelingen en artikelen</span
        >
      </label>

      <div class="g-recaptcha" data-sitekey={RECAPTCHA_SITE_KEY}></div>

      <div class="pgb-form-status" aria-live="polite"></div>
      <button class="pgb-btn" type="submit">Versturen</button>
    </form>
  </div>

  <!-- Google's reCAPTCHA script -->
  <script is:inline src="https://www.google.com/recaptcha/api.js" async defer
  ></script>

  <!-- Form handler: valideert client-side, verifieert reCAPTCHA en verstuurt server-side via /api/contact -->
  <script is:inline>
    (function () {
      const form = document.querySelector(".pgb-signup__form");
      if (!form) return;

      const statusEl = form.querySelector(".pgb-form-status");
      const submitBtn = form.querySelector(".pgb-btn");
      const nameInput = form.querySelector("#pgb-name");
      const emailInput = form.querySelector("#pgb-email");
      const pgbSelect = form.querySelector("#pgb-type");
      const messageInput = form.querySelector("#pgb-message");
      const updatesCheckbox = form.querySelector("#pgb-updates");

      const EMAIL_PATTERN = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;
      const GENERIC_FAILURE =
        "Versturen is niet gelukt. Probeer het opnieuw of mail naar info@pgbplanner.nl";

      let isSubmitting = false;

      function setStatus(msg, type = "info") {
        if (!statusEl) return;
        statusEl.textContent = msg || "";
        statusEl.classList.remove("is-error", "is-success", "is-info");
        statusEl.classList.add(
          type === "error"
            ? "is-error"
            : type === "success"
              ? "is-success"
              : "is-info",
        );
      }

      function getFormValues() {
        return {
          name: nameInput ? nameInput.value.trim() : "",
          email: emailInput ? emailInput.value.trim() : "",
          pgbType: pgbSelect && pgbSelect.value ? pgbSelect.value : null,
          message: messageInput ? messageInput.value : "",
          subscribeToUpdates: !!(updatesCheckbox && updatesCheckbox.checked),
        };
      }

      function validate(values) {
        if (!values.name) return "Vul je naam in";
        if (!EMAIL_PATTERN.test(values.email))
          return "Vul een geldig e-mailadres in";
        if (!(values.message.trim().length > 0 || values.subscribeToUpdates))
          return "Schrijf een bericht of vink aan dat je op de hoogte wilt blijven";
        return null;
      }

      function showSuccess(values) {
        const hasMessage = values.message.trim().length > 0;
        const hasUpdates = values.subscribeToUpdates === true;

        let body;
        if (hasMessage && hasUpdates) {
          body =
            "Bedankt voor je bericht. Ik reageer meestal binnen één werkdag en houd je op de hoogte.";
        } else if (hasMessage) {
          body =
            "Bedankt voor je bericht. Ik reageer meestal binnen één werkdag.";
        } else {
          body = "Je staat op de lijst. Ik houd je op de hoogte.";
        }

        const wrap = document.createElement("div");
        wrap.className = "pgb-thanks";
        wrap.setAttribute("role", "status");

        const heading = document.createElement("h3");
        heading.textContent = "Verstuurd!";

        const paragraph = document.createElement("p");
        paragraph.textContent = body;

        wrap.append(heading, paragraph);
        form.replaceWith(wrap);
      }

      async function handleSubmit(e) {
        e.preventDefault();
        if (isSubmitting) return;

        const values = getFormValues();
        const validationError = validate(values);
        if (validationError) {
          setStatus(validationError, "error");
          return;
        }

        const recaptchaToken =
          window.grecaptcha && typeof grecaptcha.getResponse === "function"
            ? grecaptcha.getResponse()
            : "";

        if (!recaptchaToken) {
          setStatus('Vink eerst het "Ik ben geen robot" vakje aan!', "error");
          return;
        }

        isSubmitting = true;
        const originalLabel = submitBtn ? submitBtn.textContent : "";
        if (submitBtn) {
          submitBtn.disabled = true;
          submitBtn.textContent = "Versturen…";
        }
        setStatus("");

        try {
          const res = await fetch("/api/contact", {
            method: "POST",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify({ ...values, recaptchaToken }),
          });

          let data = null;
          try {
            data = await res.json();
          } catch {}

          if (res.ok && data && data.success) {
            showSuccess(values);
            return;
          }

          if (data && data.reason === "recaptcha") {
            setStatus(
              "reCAPTCHA-verificatie mislukt. Probeer opnieuw.",
              "error",
            );
          } else {
            setStatus(GENERIC_FAILURE, "error");
          }

          if (window.grecaptcha && typeof grecaptcha.reset === "function") {
            grecaptcha.reset();
          }
        } catch {
          setStatus(GENERIC_FAILURE, "error");
          if (window.grecaptcha && typeof grecaptcha.reset === "function") {
            grecaptcha.reset();
          }
        } finally {
          isSubmitting = false;
          if (submitBtn) {
            submitBtn.disabled = false;
            submitBtn.textContent = originalLabel || "Versturen";
          }
        }
      }

      form.addEventListener("submit", handleSubmit);
    })();
  </script>
</section>
<style>
  /*---------------- Form styles -----------------*/
  /* ===== Layout ===== */
  .pgb-signup {
    /* background: #f6f5f2; lichte zandtint zoals je screenshot */
    /* padding: 64px 24px; */
  }

  .pgb-signup__inner {
    /* max-width: 100%; */
    margin: 0 auto;
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 48px;
  }

  .pgb-signup__copy {
    flex: 1 1 55%;
  }

  .pgb-signup__copy h2 {
    font-size: 2.5rem;
    line-height: 1.1;
    letter-spacing: 0.2px;
    margin: 0 0 16px;
    font-weight: 800;
    color: var(--color-secondary);
  }

  .text-signup {
    max-width: 600px;
    font-size: 1.25rem;
    line-height: 1.6;
    color: var(--color-body-text);
    margin-bottom: 1.8rem;
  }

  /* ===== Form Card ===== */
  .pgb-signup__form {
    flex: 0 0 520px; /* vaste breedte zoals in je design */
    background: #ffffff;
    /* border: 1px solid var(--color-form-border); */
    border-radius: 12px;
    padding: 40px 20px;
    display: grid;
    gap: 16px;
    box-shadow:
      0 4px 6px -2px #1212170d,
      0 10px 15px -3px #17141214;
  }

  .pgb-field {
    display: grid;
    gap: 6px;
  }

  .pgb-label {
    position: absolute;
    left: -9999px; /* visueel verborgen, wel toegankelijk */
  }

  .pgb-signup__form input,
  .pgb-signup__form select,
  .pgb-signup__form textarea {
    width: 100%;
    padding: 0 14px;
    border: 1px solid #d7d4cf;
    border-radius: 8px;
    font-family: inherit;
    font-size: 16px;
    color: #222;
    background: #fff;
    outline: none;
    transition:
      border-color 120ms ease,
      box-shadow 120ms ease;
  }

  .pgb-signup__form input,
  .pgb-signup__form select {
    height: 48px;
  }

  .pgb-signup__form textarea {
    min-height: 140px;
    padding-block: 12px;
  }

  .pgb-signup__form select {
    appearance: none;
    background-image: linear-gradient(45deg, transparent 50%, #6b7280 50%),
      linear-gradient(135deg, #6b7280 50%, transparent 50%),
      linear-gradient(to right, transparent, transparent);
    background-position:
      calc(100% - 22px) 22px,
      calc(100% - 16px) 22px,
      0 0;
    background-size:
      6px 6px,
      6px 6px,
      100% 100%;
    background-repeat: no-repeat;
  }

  .pgb-signup__form input::placeholder,
  .pgb-signup__form textarea::placeholder,
  .pgb-signup__form select:invalid {
    color: #9aa0a6;
  }

  .pgb-signup__form input:focus,
  .pgb-signup__form select:focus,
  .pgb-signup__form textarea:focus {
    border-color: #3b82f6;
    box-shadow: 0 0 0 3px rgba(59, 130, 246, 0.15);
  }

  .pgb-btn {
    margin-top: 4px;
    height: 46px;
    border: none;
    border-radius: 10px;
    padding: 0 18px;
    font-size: 16px;
    font-weight: 700;
    cursor: pointer;
    background: #3b6fb7; /* blauw zoals je button */
    color: #fff;
    transition:
      transform 120ms ease,
      filter 120ms ease;
  }

  .pgb-btn:hover {
    filter: brightness(1.05);
  }
  .pgb-btn:active {
    transform: translateY(1px);
  }

  .pgb-checkbox {
    display: flex;
    align-items: flex-start; /* label kan meerregelig zijn */
    gap: 0.8rem; /* kleine ruimte tussen box en tekst */
  }

  .pgb-checkbox input[type="checkbox"] {
    margin: 0; /* reset default browser margin */
    width: 20px;
    height: 20px;
    flex: 0 0 auto; /* voorkom uitrekken */
    /* optional: accent-color voor thema
  accent-color: #1f6feb;
  */
  }

  .pgb-checkbox__label {
    line-height: 1.3;
  }

  .pgb-mail-link {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem; /* ruimte tussen icon en tekst */
    font-weight: 500;
    color: var(--color-body-text); /* of var(--text-color) */
    text-decoration: none;
    transition: color 0.2s ease;
  }

  .pgb-mail-link:hover {
    color: var(--color-l-blue); /* zachte blauwe hoverkleur */
  }

  .pgb-mail-link svg {
    flex-shrink: 0;
    width: 20px;
    height: 20px;
  }

  .socials-wrapper{
    display: flex;
    gap: 1rem;
    margin-top: 2rem;
  }

  /* ===== Form feedback states ===== */
  :global(.pgb-thanks h3) {
    color: var(--color-secondary);
  }

  .pgb-form-status.is-success {
    color: var(--color-secondary);
  }

  .pgb-form-status.is-error {
    color: #d45a5a;
  }

  /* ===== Responsive Styles ===== */

  /* Tablet (max 1024px) */
  @media (max-width: 1024px) {
    .pgb-signup__inner {
      gap: 32px;
    }

    .pgb-signup__form {
      flex: 0 0 440px;
      padding: 32px 24px;
    }

    .pgb-signup__copy h2 {
      font-size: 2rem;
    }

    .text-signup {
      font-size: 1.125rem;
    }
  }

  /* Tablet portrait / grote mobiel (max 768px) */
  @media (max-width: 768px) {
    .pgb-signup__inner {
      flex-direction: column;
      gap: 40px;
    }

    .pgb-signup__copy {
      flex: 1 1 auto;
    }

    .pgb-signup__form {
      flex: 1 1 auto;
      width: 100%;
      max-width: 520px;
    }

    .pgb-signup__copy h2 {
      font-size: 1.875rem;
    }
  }

  /* Mobiel (max 480px) */
  @media (max-width: 480px) {
    .pgb-signup__inner {
      gap: 32px;
    }

    .pgb-signup__copy h2 {
      font-size: 1.625rem;
    }

    .text-signup {
      font-size: 1rem;
      margin-bottom: 1.5rem;
    }

    .pgb-signup__form {
      padding: 28px 20px;
      gap: 14px;
    }

    .pgb-signup__form input,
    .pgb-signup__form select {
      height: 44px;
      font-size: 16px; /* voorkomt zoom op iOS */
    }

    .pgb-btn {
      height: 44px;
      font-size: 15px;
    }

    .pgb-mail-link {
      font-size: 0.9375rem;
    }

    .text-ps {
      font-size: 0.875rem;
    }
  }
</style>
