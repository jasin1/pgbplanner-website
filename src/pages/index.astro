---
import BaseLayout from "../layouts/BaseLayout.astro";
import Button from "../components/Button.astro";
import Header from "../components/Header.astro";
import CheckIcon from "../components/CheckIcon.astro";
import Card from "../components/card.astro";
import ParentsIcon from "../components/ParentsIcon.astro";
import HouderIcon from "../components/HouderIcon.astro";
import ProsIcon from "../components/ProsIcon.astro";
import PaperIcon from "../components/PaperIcon.astro";
import StatsIcon from "../components/StatsIcon.astro";
import StepCard from "../components/StepCard.astro";
import SignupSection from "../components/SignupSection.astro";
import FaqSection from "../components/FaqSection.astro";
import CalendarIcon from "../components/CalendarIcon.astro";

const dankje = Astro.url.searchParams.get("dankje") === "1";
---

<BaseLayout title="PGB Planner, weet het hele jaar of je uitkomt met je budget" description="Weet het hele jaar of je uitkomt met je PGB-budget. PGB Planner rekent je uitgaven en zorgverleners automatisch door, zodat je niet voor verrassingen komt te staan.">
  <main>
    <div class="hero">
      <h1>
        <span class="font-color-primary">Weet het hele jaar</span><br />
        <span class="font-color-secondary">of je uitkomt met je PGB-budget.</span>
      </h1>
      <p class="body-large">
        <span class="text-bold">PGB Planner</span> rekent je uitgaven en zorgverleners
        automatisch door, zodat je op tijd ziet of je op koers ligt en niet voor
        verrassingen komt te staan.
      </p>
      <div class="buttons-wrapper">
        <a href="https://app.pgbplanner.nl/registreer" class="btn btn-primary">Probeer 21 dagen gratis</a>
        <a href="#contact" class="btn btn-secondary">Blijf op de hoogte</a>
      </div>
      <p class="hero-price-line">Daarna €20 per maand · Maandelijks opzegbaar</p>
      <div class="hero-img-wrapper">
        <picture>
          <source
            srcset="/Dashboard-400w.avif 400w, 
              /Dashboard-800w.avif 800w, 
              /Dashboard-1200w.avif 1200w, 
              /Dashboard-1600w.avif 1600w"
            type="image/avif"
          />
          <source
            srcset="/Dashboard-400w.webp 400w, 
              /Dashboard-800w.webp 800w, 
              /Dashboard-1200w.webp 1200w, 
              /Dashboard-1600w.webp 1600w"
            type="image/webp"
          />
          <img
            src="/Dashboard-1200w.jpg"
            srcset="/Dashboard-400w.jpg 400w,
              /Dashboard-800w.jpg 800w,
              /Dashboard-1200w.jpg 1200w,
              /Dashboard-1600w.jpg 1600w"
            sizes="(max-width: 640px) 400px,
             (max-width: 1024px) 800px,
             (max-width: 1536px) 1200px,
             1600px"
            width="1600"
            height="821"
            loading="eager"
            fetchpriority="high"
            decoding="async"
            alt="Dashboard van PGB Planner met budgetstatus, uitgaven en vooruitblik"
          />
        </picture>
      </div>
    </div>
    <section class="flex-center" id="svb">
      <div class="container svb-section">
        <div class="section-heading-small">
          <h2>Naast het SVB-portaal, een stap vooruit</h2>
        </div>
        <div class="svb-text">
          <p>
            Je regelt je PGB al via het SVB-portaal. Declaraties indienen,
            zorgovereenkomsten beheren, betalingen volgen, dat blijft precies
            zoals het is. PGB Planner komt daar niet voor in de plaats.
          </p>
          <p>
            Wat het portaal laat zien, is wat er tot nu toe is uitgegeven. Wat
            je niet ziet, is waar dat naartoe leidt. Geef je deze maand iets
            meer uit aan een zorgverlener, dan werkt dat door in de rest van
            het jaar, maar dat verband zie je nergens totdat het budget zelf
            opraakt.
          </p>
          <p>
            PGB Planner rekent die lijn door. Geef je meer uren door, neem je
            een extra zorgverlener aan, of veranderen je kosten? Dan zie je
            meteen hoeveel budget je overhoudt en of je nog uitkomt tot het
            einde van het jaar, niet pas achteraf, maar vóórdat je de keuze
            maakt.
          </p>
          <p>Geen vervanging van de SVB, maar de rust die erbij ontbrak.</p>
        </div>
      </div>
    </section>
    <section class="flex-center section-bg-color padding-bottom" id="over">
      <div class="container problem-section">
        <div class="section-txt-block">
          <div class="section-heading-small">
            <h2>Je PGB bijhouden werkt, totdat er iets verandert.</h2>
          </div>
          <p>
            Veel mensen houden hun PGB bij in Excel, op papier of in een eigen
            systeem. Dat werkt vaak prima, zolang alles hetzelfde blijft.
          </p>
          <p>
            Komen er meer uren bij, verandert een tarief, of komt er een
            extra zorgverlener? Dan ben jij degene die opnieuw moet uitzoeken
            of je nog uitkomt met je budget.
          </p>
          <p>
            Niet omdat Excel moeilijk is, maar omdat het overzicht bewaren
            altijd bij jou blijft liggen.
          </p>
          <p>
            PGB Planner rekent met je mee, zodat je sneller weet of je nog
            uitkomt, zonder dat je het zelf steeds hoeft na te lopen.
          </p>
        </div>
        <div class="img-wrapper">
          <img src="/problem-img-2.png" alt="" />
        </div>
      </div>
    </section>
    <section class="flex-center">
      <div class="container">
        <div class="section-heading">
          <h2>Ontstaan vanuit de praktijk,<br />niet vanuit een spreadsheet</h2>
          <p class="body-large text-align-center">
            Ik heb jarenlang zelf een PGB-administratie bijgehouden en weet
            hoeveel uitzoekwerk erbij komt kijken als er iets verandert in een
            planning, tarief of zorgverlener. PGB Planner is ontstaan vanuit die
            ervaring, gebouwd door iemand die precies begrijpt waarom overzicht
            en vooruitkijken zo belangrijk zijn. Het is de tool die ik zelf
            graag eerder had willen hebben.
          </p>
        </div>
      </div>
    </section>
    <section class="container padding-bottom">
      <div class="container container-block cta-block border-soft">
        <div class="text-card">
          <h2>Wil je weten of je uitkomt met je budget?</h2>
          <p class="txt-w-60ch">
            Je voegt je budget en zorgverleners toe, en ziet binnen een paar
            minuten of je op koers ligt. 21 dagen gratis, geen
            betaalgegevens, geen verplichtingen.
          </p>
          <div class="btn-one-wrapper">
            <a class="btn btn-primary cta-desktop" href="https://app.pgbplanner.nl/registreer"
              >Probeer 21 dagen gratis</a
            >
          </div>
        </div>
        <div class="logo-in-wrapper">
          <img src="/main-logo-v2.svg" alt="" />
        </div>
      </div>
    </section>
    <section class="flex-center" id="preview">
      <div class="container">
        <div class="section-heading">
          <h2>Zie vooraf of je uitkomt</h2>
          <p class="body-large text-align-center">
            Met Vooruitblik zie je wat je huidige planning betekent voor de
            rest van het jaar. Probeer andere uren, tarieven of
            werkgeverslasten uit en zie direct of je uitkomt met je budget,
            zonder iets aan je bestaande planning te veranderen.
          </p>
        </div>
        <div class="hero-img-wrapper border-soft">
          <picture>
            <source
              srcset="/Vooruitblik-400w.avif 400w,
                /Vooruitblik-800w.avif 800w,
                /Vooruitblik-1200w.avif 1200w,
                /Vooruitblik-1600w.avif 1600w"
              type="image/avif"
            />
            <source
              srcset="/Vooruitblik-400w.webp 400w,
                /Vooruitblik-800w.webp 800w,
                /Vooruitblik-1200w.webp 1200w,
                /Vooruitblik-1600w.webp 1600w"
              type="image/webp"
            />
            <img
              src="/Vooruitblik-1200w.jpg"
              srcset="/Vooruitblik-400w.jpg 400w,
                /Vooruitblik-800w.jpg 800w,
                /Vooruitblik-1200w.jpg 1200w,
                /Vooruitblik-1600w.jpg 1600w"
              sizes="(max-width: 640px) 400px,
               (max-width: 1024px) 800px,
               (max-width: 1536px) 1200px,
               1600px"
              width="1600"
              height="821"
              loading="lazy"
              decoding="async"
              alt="Vooruitblik in PGB Planner met medewerkers, geplande kosten en verwacht resterend budget"
            />
          </picture>
        </div>
      </div>
    </section>
    <section class="flex-center section-bg-color">
      <div class="container container--wide">
        <div class="section-heading">
          <h2>Voor wie is PGB Planner bedoeld?</h2>
        </div>
        <div class="cards-wrapper">
          <Card
            title="Ouders met een kind met een PGB"
            description="Die het PGB van hun kind beheren en graag overzicht houden over het hele jaar."
          >
            <ParentsIcon slot="icon" />
          </Card>
          <Card
            title="Mensen met een eigen PGB"
            description="Die zelf hun administratie doen en op één plek willen zien waar ze staan."
          >
            <HouderIcon slot="icon" />
          </Card>
          <Card
            title="Partners en familieleden die een PGB beheren"
            description="Die helpen bij het beheren van een PGB en minder tijd kwijt willen zijn aan uitzoekwerk."
          >
            <ProsIcon slot="icon" />
          </Card>
        </div>
        <div class="btn-one-wrapper flex-align-center">
          <a class="btn btn-primary cta-desktop" href="https://app.pgbplanner.nl/registreer"
            >Probeer 21 dagen gratis
          </a>
        </div>
      </div>
    </section>
    <section class="flex-center section-bg-color padding-bottom" id="hoe">
      <div class="container flex-colomn">
        <div class="section-heading">
          <h2 class="h2">Zo werkt PGB Planner</h2>
        </div>
        <div class="howitworks__list">
          <StepCard
            title="Voeg je budget en zorgverleners toe"
            description="Je vult één keer in met wie je werkt en welk budget je hebt, zodat alles op één plek staat."
          >
            <PaperIcon
              slot="icon"
              class="icon"
              style="color: var(--color-secondary);"
            />
          </StepCard>

          <StepCard
            title="Houd je uitgaven bij"
            description="Registreer wat je uitgeeft, zoals je dat nu ook al doet."
          >
            <CalendarIcon
              slot="icon"
              class="icon"
              style="color: var(--color-secondary);"
            />
          </StepCard>

          <StepCard
            title="Zie meteen of je nog uitkomt"
            description="PGB Planner rekent mee, zodat je op elk moment weet of je het hele jaar uitkomt met je budget."
          >
            <StatsIcon
              slot="icon"
              class="icon"
              style="color: var(--color-secondary);"
            />
          </StepCard>
        </div>
      </div>
    </section>
    <div class="container">
      <FaqSection />
    </div>
    <SignupSection />
  </main>
  <style>
    .hero {
      background-color: var(--color-bg);
      width: 100%;
      padding: 4.5rem 1rem;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      text-align: center;
    }

    .hero h1 {
      margin-bottom: 1rem;
    }

    .hero p {
      max-width: 680px;
    }

    .hero-img-wrapper {
      width: 100%; /* was 1200px */
      max-width: 1200px; /* behoud upper bound */
      margin-inline: auto; /* centreren */
      border-radius: 0.75rem;
      overflow: hidden; /* zorgt dat rounded corners ook voor de img gelden */
      box-shadow:
        0 4px 6px -2px #1212170d,
        0 10px 15px -3px #17141214;
    }

    .hero-img-wrapper picture {
      display: block;
      inline-size: 100%;
    }

    .hero-img-wrapper img {
      display: block;
      inline-size: 100%;
      block-size: auto;
      object-fit: cover;
      border-radius: 0; /* corners komen nu van de wrapper */
    }

    .text-bold {
      font-weight: bold;
    }

    .hero-price-line {
      font-size: 1rem;
      color: var(--color-body-text);
      margin-top: 0.5rem;
      margin-bottom: 3rem;
    }

    /* Buttons-wrapper's global bottom margin is now owned by .hero-price-line above */
    .hero .buttons-wrapper {
      margin-bottom: 0;
    }

    .hero .btn-primary {
      font-size: 1.25rem;
    }

    .problem-section {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 1rem;
    }

    .section-txt-block {
      display: flex;
      flex-direction: column;
      gap: 1.5rem;
      max-width: 35.5rem;
    }

    .section-sub-header {
      font-size: 1.5rem;
    }

    .svb-section {
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 1.5rem;
      max-width: 42rem;
      margin-inline: auto;
      text-align: left;
    }

    .svb-text {
      display: flex;
      flex-direction: column;
      gap: 1.25rem;
    }

    .alt-h2 {
      font-size: 1.5rem;
    }

    .section-heading {
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 1rem;
      margin-bottom: 2.5rem;
      /* max-width: 600px; */
    }

    .section-heading-small {
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 1rem;
      margin-bottom: 1rem;
    }

    .img-wrapper img {
      width: 100%;
      max-width: 550px;
      height: auto;
    }

    .text-card {
      padding: 1.5rem 0rem;
      border-radius: 1rem;
      display: flex;
      flex-direction: column;
      gap: 1.5rem;
    }

    .cards-wrapper {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(350px, 1fr));
      gap: 2rem;
      margin-bottom: 2.5rem;
    }

    .howitworks__list {
      max-width: 720px;
      margin-bottom: 1.5rem;
      display: grid;
      gap: 16px;
    }
    .icon {
      color: var(--color-secondary);
    }

    @media (max-width: 1024px) {
      .problem-section {
        flex-direction: column;
        align-items: center;
        gap: 2rem;
        text-align: left;
      }

      .section-txt-block {
        max-width: 42rem;
        padding-inline: 1rem;
      }

      .img-wrapper img {
        max-width: 720px;
      }
    }

    @media (max-width: 640px) {
      .section-txt-block {
        max-width: 100%;
      }
      .img-wrapper img {
        max-width: 100%;
      }
    }

    @media (min-width: 1024px) {
      .cards-wrapper {
        grid-template-columns: repeat(3, 1fr);
      }
    }

    /* Maak alleen deze container ruimer op desktop+ */
    @media (min-width: 1280px) {
      .container--wide {
        max-width: 1400px;
      } /* van 1200 → 1400 */
    }
    @media (min-width: 1536px) {
      .container--wide {
        max-width: 1500px;
      } /* extra ruimte op hele brede schermen */
    }

    /* Klein beetje minder gap helpt ook visueel */
    @media (min-width: 1024px) {
      .cards-wrapper {
        gap: 1.5rem;
      } /* was 2rem */
    }

    @media (max-width: 480px) {
      .cards-wrapper {
        grid-template-columns: 1fr !important;
        gap: 1rem;
      }
    }

    @media (max-width: 768px) {
      .howitworks__list {
        padding-inline: 0rem;
        max-width: 42rem; /* iets ruimer dan 720px op tablet */
      }
    }
    @media (max-width: 640px) {
      .howitworks__list {
        max-width: 100%;
      }
    }

    @media (max-width: 640px) {
      .email-collect,
      .launch-form,
      .input-group {
        max-width: 100%;
      }
      .input-group {
        padding-left: 1rem;
      }
    }
    @media (max-width: 400px) {
      .input-group {
        padding-left: 0.75rem;
      }
    }

    @media (max-width: 640px) {
      .text-card {
        gap: 1rem;
        padding: 1rem 0;
      }
      .section-heading {
        margin-bottom: 1.5rem;
        padding-inline: 1rem;
        align-items: flex-start;
      }
      .section-heading-small {
        gap: 0.75rem;
        margin-bottom: 0.75rem;
      }
    }

    @media (max-width: 640px) {
      section[id] {
        scroll-margin-top: 72px;
      } /* stem af op --header-h */
    }

    @media (max-width: 1024px) {
      .hero {
        padding: 3.5rem 2rem;
      }
    }
    @media (max-width: 640px) {
      .hero {
        padding: 3rem 1rem;
      }

      .hero-price-line {
        margin-bottom: 2rem;
      }

      /* Stack the two hero CTAs vertically on mobile, primary on top */
      .hero .buttons-wrapper {
        flex-direction: column;
        align-items: stretch;
      }

      .hero .buttons-wrapper .btn {
        flex: none;
        width: 100%;
      }
    }
  </style>
</BaseLayout>
