---
import BaseLayout from "../layouts/BaseLayout.astro";

const baseEmbedUrl =
  "https://tally.so/embed/818ZOk?alignLeft=1&transparentBackground=1&dynamicHeight=1";
const incoming = Astro.url.searchParams.toString();
const tallySrc = incoming ? `${baseEmbedUrl}&${incoming}` : baseEmbedUrl;
---

<BaseLayout
  title="Feedback | PGB Planner"
  description="Deel je feedback over PGB Planner."
>
  <div class="content-wrapper">
    <iframe
      src={tallySrc}
      loading="lazy"
      width="100%"
      height="500"
      frameborder="0"
      marginheight="0"
      marginwidth="0"
      title="Feedback PGB Planner"></iframe>
  </div>

  <style>
    .content-wrapper {
      margin: 3rem 0;
      padding: 0 1rem;
    }
  </style>
</BaseLayout>
